{
  "name": "tp_dn_github",
  "version": "1.0.0",
  "description": "A project for CI/CD practice",
  "main": "app.js",
  "type": "module",
  "scripts": {
    "lint": "eslint \"**/*.js\"",
    "serve": "http-server -p 8080",
    "pa11y": "pa11y-ci",
    "test:a11y": "start-server-and-test \"npm run serve\" http://localhost:8080 \"npm run pa11y\"",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --testPathIgnorePatterns=tests-e2e",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.60.0",
    "eslint": "^8.57.1",
    "globals": "^15.0.0",
    "htmlhint": "^1.9.2",
    "http-server": "^14.1.1",
    "jest": "^30.4.2",
    "start-server-and-test": "^3.0.5",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0"
  },
  "dependencies": {
    "htmlint": "^0.0.7"
  }
}
